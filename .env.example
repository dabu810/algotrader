# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose which LLM provider to use. Only the matching API key needs to be set.
# Supported: anthropic | openai | gemini | mistral
LLM_PROVIDER=anthropic

# Optional: override the default model for the chosen provider
# Defaults: claude-opus-4-6 | gpt-4o | gemini-2.0-flash | mistral-large-latest
# LLM_MODEL=claude-opus-4-6

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── OpenAI (GPT) ──────────────────────────────────────────────────────────────
# OPENAI_API_KEY=your-openai-api-key-here

# ── Google (Gemini) ───────────────────────────────────────────────────────────
# GOOGLE_API_KEY=your-google-api-key-here

# ── Mistral ───────────────────────────────────────────────────────────────────
# MISTRAL_API_KEY=your-mistral-api-key-here

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# 1. Sign up free: https://www.twilio.com
# 2. Console → Messaging → Try it out → Send a WhatsApp message
# 3. Activate sandbox: text "join <keyword>" from your phone to +1 415 523 8886
# 4. Sandbox settings → "When a message comes in" → set your ngrok URL + /webhook

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp number (country code, no spaces)
# India: whatsapp:+919876543210
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── TradingView Technical Analysis Agent ──────────────────────────────────────
# MCP server command — installed via: pip install mcp-tradingview-server
# Change this if you use a different TradingView MCP server implementation
TRADINGVIEW_MCP_SERVER=mcp-tradingview
